PORT=3001
OWNER_EMAIL=you@example.com
SMTP_USER=you@gmail.com
FROM_EMAIL=you@gmail.com

# Gmail (@gmail.com): OAuth2 (App Password no longer required for many accounts)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_oauth_refresh_token

# Non-Gmail SMTP (omit GOOGLE_* and set these instead)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_PASS=your_smtp_password

OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini
CLIENT_URL=http://localhost:5173
SITE_URL=http://localhost:5173
# true — allow https://*.vercel.app for PR previews (optional)
ALLOW_VERCEL_PREVIEWS=false
